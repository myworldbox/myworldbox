[
    {
        "id": 1,
        "content0": "無懼世事\n\t變改"
    },
    {
        "id": 2,
        "content0": "祝你在亂流下\n\t平安"
    },
    {
        "id": 3,
        "content0": "悠悠乎與\n\t灝氣俱"
    },
    {
        "id": 4,
        "content0": "滿招損\n\t謙受益"
    },
    {
        "id": 5,
        "content0": "老驥伏櫪\n\t志在千里"
    },
    {
        "id": 6,
        "content0": "踏破鐵鞋無覓處\n\t得來全不費工夫"
    },
    {
        "id": 7,
        "content0": "欲窮千里目\n\t更上一層樓"
    },
    {
        "id": 8,
        "content0": "藍藍天空\n\t高掛我的夢想"
    },
    {
        "id": 9,
        "content0": "寧化飛灰\n\t不作浮塵"
    },
    {
        "id": 10,
        "content0": "千磨萬擊\n\t還堅韌"
    }
]